# Server configuration
NODE_ENV=development
PORT=3000

# Tinder API configuration
TINDER_API_BASE_URL=https://api.gotinder.com
TINDER_IMAGES_URL=https://images-ssl.gotinder.com
TINDER_STATS_URL=https://etl.tindersparks.com
TINDER_API_TIMEOUT=30000
TINDER_API_MAX_RETRIES=3

# Cache configuration
CACHE_TTL=300
CACHE_CHECK_PERIOD=60

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Security configuration
TOKEN_SECRET=your-secret-key-here
TOKEN_EXPIRY=24h

# Logging configuration
LOG_LEVEL=info

# Tinder anti-bot fingerprinting headers (captured via capture-auth.ts)
# Run: npx tsx capture-auth.ts — log in, close browser, paste output here
TINDER_HEADER_USER_AGENT=
TINDER_HEADER_APP_VERSION=
TINDER_HEADER_PLATFORM=
TINDER_HEADER_X_SUPPORTED_IMAGE_FORMATS=
TINDER_HEADER_X_AUTH_TOKEN=
TINDER_HEADER_X_CLIENT_VERSION=
TINDER_HEADER_PERSISTENT_DEVICE_ID=
TINDER_HEADER_INSTALL_ID=
TINDER_HEADER_TINDER_VERSION=
TINDER_HEADER_OS_VERSION=
TINDER_HEADER_STORE_VARIANT=
TINDER_HEADER_FUNNEL_SESSION_ID=
TINDER_HEADER_APP_SESSION_ID=
TINDER_HEADER_IS_DARK_MODE=